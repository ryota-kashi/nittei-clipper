{
  "manifest_version": 3,
  "name": "日程クリッパー",
  "description": "日程候補の提案文をポップアップから素早く作成・コピーできる拡張機能です。",
  "version": "2.9.1",
  "action": {
    "default_title": "日程クリッパー"
  },
  "permissions": [
    "clipboardWrite",
    "storage",
    "sidePanel"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://calendar.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}